{:source-paths ["src"]

 :dependencies
 [[reagent "1.2.0"]]

 :dev-http {8080 "public"}

 :builds
 {:app {:target :browser
        :output-dir "public/js"
        :asset-path "/js"
        :js-options {:js-provider :shadow
                     :injected-libs ["process/browser"]}
        :modules {:main {:init-fn dashboard.core/init}}}}}
